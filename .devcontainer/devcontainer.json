{
  "name": "Hugo Blog",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "tamasfe.even-better-toml",
        "yzhang.markdown-all-in-one",
        "github.vscode-github-actions"
      ],
      "settings": {
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 120,
        "files.trimTrailingWhitespace": true,
        "[markdown]": {
          "editor.wordWrap": "wordWrapColumn",
          "editor.wordWrapColumn": 120
        }
      }
    }
  },
  "forwardPorts": [
    1313
  ],
  "portsAttributes": {
    "1313": {
      "label": "Hugo Server",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "git submodule update --init --recursive && pipx install pre-commit && pre-commit install"
}
